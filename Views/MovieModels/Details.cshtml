@model CineScope.Models.MovieModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="row g-0">

            <!-- Poster -->
            <div class="col-md-4">

                <img src="@Model.PosterUrl"
                     alt="@Model.Title"
                     class="img-fluid h-100 w-100"
                     style="object-fit: cover; min-height: 500px;" />

            </div>

            <!-- Movie Information -->
            <div class="col-md-8">

                <div class="card-body p-4">

                    <h1 class="fw-bold mb-3">
                        @Model.Title
                    </h1>

                    <div class="mb-3">

                        <span class="badge bg-primary fs-6 me-2">
                            @Model.Genre
                        </span>

                        <span class="badge bg-warning text-dark fs-6">
                            ★ @Model.Rating
                        </span>

                    </div>

                    <hr />

                    <h5>Description</h5>

                    <p class="text-muted">
                        @Model.Description
                    </p>

                    <div class="row mt-4">

                        <div class="col-md-6 mb-3">

                            <h6 class="text-secondary">
                                Release Year
                            </h6>

                            <p class="fs-5">
                                @Model.ReleaseYear
                            </p>

                        </div>

                        <div class="col-md-6 mb-3">

                            <h6 class="text-secondary">
                                Duration
                            </h6>

                            <p class="fs-5">
                                @Model.Duration min
                            </p>

                        </div>

                    </div>

                    <div class="mt-4">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            ← Back to Movies

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>