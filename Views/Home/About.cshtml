@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold">🎬 CineScope</h1>
        <p>
            Discover, explore, and share your passion for movies.
        </p>
    </div>

    <!-- About Card -->
    <div class="card border-0 shadow-lg rounded-4">
        <div class="card-body p-5">

            <h2 class="mb-4">Who We Are</h2>

            <p class="fs-5">
                CineScope is a movie discovery platform built for movie lovers.
                Whether you're searching for your next favorite film, keeping track
                of ratings, or exploring different genres, CineScope makes it easy
                to find and enjoy great movies.
            </p>

            <p class="fs-5">
                Our goal is to create a simple and enjoyable experience where users
                can browse movies, view detailed information, save favorites,
                and share opinions through ratings and reviews.
            </p>

        </div>
    </div>

    <!-- Features -->
    <div class="row mt-5 g-4">

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h3>🔍 Discover</h3>
                    <p class="text-muted">
                        Search and browse a growing collection of movies from
                        different genres and eras.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h3>⭐ Rate</h3>
                    <p class="text-muted">
                        Share your opinions and see how other movie enthusiasts
                        rate their favorite films.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h3>❤️ Save</h3>
                    <p class="text-muted">
                        Keep track of your favorite movies and build your own
                        personal watchlist.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- Mission -->
    <div class="mt-5 text-center">
        <h2>Our Mission</h2>
        <p>
            To help movie fans discover great stories and connect through a shared love of cinema.
        </p>
    </div>

</div>